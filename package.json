{
	"name": "@concero/ui-kit",
	"private": false,
	"version": "0.2.23",
	"author": "kowka_vn",
	"license": "ISC",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"repository": {
		"type": "github",
		"url": "https://github.com/concero/ui-kit"
	},
	"type": "module",
	"main": "dist/index.cjs.js",
	"module": "dist/index.es.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.es.js",
			"require": "./dist/index.cjs.js"
		},
		"./styles/concero/index.css": "./dist/styles/concero/index.css",
		"./styles/lanca/index.css": "./dist/styles/lanca/index.css"
	},
	"files": [
		"dist",
		"README.md",
		"ForDevelopers.md"
	],
	"scripts": {
		"publish": "npm publish --access=public",
		"dev": "vite",
		"build": "vite build",
		"lint:ts": "eslint .",
		"lint:ts:fix": "eslint . --fix",
		"lint:css": "npx stylelint \"src/**/*.{css,pcss}\"",
		"lint:css:fix": "npx stylelint \"src/**/*.{css,pcss}\" --fix",
		"lint": "npm run lint:ts && npm run lint:css",
		"lint:fix": "npm run lint:ts:fix && npm run lint:css:fix",
		"format:check": "npx prettier . --check",
		"format:fix": "npx prettier . --write",
		"sb": "storybook dev -p 6006 --no-open",
		"sb:build": "storybook build",
		"precommit": "npm run sb:build && npm run lint && npm run format:check",
		"prepare": "husky"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/js": "^9.39.4",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-onboarding": "^10.3.3",
		"@storybook/react-vite": "^10.3.3",
		"@svgr/plugin-svgo": "^8.1.0",
		"@types/css-modules": "^1.0.5",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.4",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.3.3",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"path": "^0.12.7",
		"postcss": "^8.5.8",
		"postcss-modules": "^6.0.1",
		"precss": "^4.0.0",
		"prettier": "^3.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"storybook": "^10.3.3",
		"stylelint": "^16.26.1",
		"stylelint-config-recommended-scss": "^17.0.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"typescript-plugin-css-modules": "^5.2.0",
		"vite": "^6.1.0",
		"vite-plugin-css-injected-by-js": "^3.5.2",
		"vite-plugin-dts": "^4.5.0",
		"vite-plugin-static-copy": "^2.3.0",
		"vite-plugin-stylelint": "^6.0.0",
		"vite-plugin-svgr": "^4.3.0",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"dependencies": {
		"clsx": "^2.1.1"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"sideEffects": false,
	"eslintConfig": {
		"extends": [
			"plugin:storybook/recommended"
		]
	},
	"overrides": {
		"storybook": "$storybook",
		"typescript": "^6.0.2"
	}
}
